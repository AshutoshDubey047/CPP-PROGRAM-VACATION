{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run C++ File",
      "type": "shell",
      "command": "g++ -Wall -o \"${fileDirname}/output/${fileBasenameNoExtension}.exe\" \"${file}\" && echo. && echo ===== OUTPUT ===== && \"${fileDirname}/output/${fileBasenameNoExtension}.exe\"",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Run Python File",
      "type": "shell",
      "command": "python",
      "args": ["${file}"],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Run Node File",
      "type": "shell",
      "command": "node",
      "args": ["${file}"],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Run Java File",
      "type": "shell",
      "command": "javac \"${file}\" && echo. && echo ===== OUTPUT ===== && java -cp \"${fileDirname}\" ${fileBasenameNoExtension}",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Run Go File",
      "type": "shell",
      "command": "go run \"${file}\"",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Cargo Run (Rust)",
      "type": "shell",
      "command": "cargo run",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build & Run C++",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "cd \"${fileDirname}\" && g++ -Wall -o \"${fileDirname}/output/${fileBasenameNoExtension}.exe\" \"${file}\" && echo. && echo ===== OUTPUT ===== && \"${fileDirname}/output/${fileBasenameNoExtension}.exe\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "echo": true,
        "showReuseMessage": false,
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}

