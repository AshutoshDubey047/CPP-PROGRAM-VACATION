{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build & Run C++",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "cd \"${fileDirname}\" && g++ -Wall -o \"${fileDirname}/output/${fileBasenameNoExtension}.exe\" \"${file}\" && echo. && echo ===== OUTPUT ===== && \"${fileDirname}/output/${fileBasenameNoExtension}.exe\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "echo": true,
        "showReuseMessage": false,
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}

