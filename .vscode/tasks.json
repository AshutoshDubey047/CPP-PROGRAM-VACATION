{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Clean & Build C++",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "del /F /Q \"${workspaceFolder}\\YT SERIES\\array\\output\\*.exe\" 2>nul & g++ -o \"${workspaceFolder}\\YT SERIES\\array\\output\\sum&product.exe\" \"${file}\""
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false
      }
    }
  ]
}
